<Window x:Class="Hochbeet_Planer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hochbeet_Planer"
        mc:Ignorable="d"
        Title="Hochbeet Planer Editor" Height="600" Width="1000">
    <!--Titelbalken oben "Hochbeet Planer Editor"-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#1a6b4a" Padding="10">
            <TextBlock Text="Hochbeet Planer Editor" Foreground="#e8f5ee" FontSize="18" FontWeight="Bold"/>
        </Border>
        <!--Hauptbereich der Seite (Beet mittig & Pflanzen rechts)-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            <!--Mitte Hochbeetbereich-->
            <ScrollViewer Grid.Column="0" Margin="8" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"> <!--zum scrollen-->
                <Grid x:Name="grdHochbeet" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            </ScrollViewer>           
            <!--rechter Bereich-->

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Background="#f0f0e0" Margin="0" Width="auto" >                
                <!--rechts Maße-->
                <Border Background="#1a6b4a" Padding="8" HorizontalAlignment="Stretch">
                    <TextBlock Text="Hochbeet Maße" Foreground="#e8f5ee" FontSize="14" FontWeight="Bold"/>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="8,8,8,4">
                    <TextBlock Text="Breite(cm):" VerticalAlignment="Center" Margin=" 0,0,8,0" />
                    <TextBox x:Name="txtBreite" Width="80"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,4,8,8">
                    <TextBlock Text="Länge(cm):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="txtLaenge" Width="80"/>
                </StackPanel>
                <Button x:Name="btnBeetGenerieren" Content="Beet generieren" Margin="8,4,8,8" 
                        Background="#1a6b4a" Foreground="#e8f5ee" Click="btnBeetGenerieren_Click"/>
                <!--Beetname-->
                <Border Background="#1a6b4a" Padding="8" HorizontalAlignment="Stretch">
                    <TextBlock Text="Beetname" Foreground="#e8f5ee" FontSize="14" FontWeight="Bold"/>
                </Border>
                <TextBox x:Name="txtBeetName" Margin="8,4,8,8" Text="Mein Beet"/>
                <!--Gespeicherte Beete--> 
                <Border Background="#1a6b4a" Padding="8" HorizontalAlignment="Stretch">
                    <TextBlock Text="Gespeicherte Beete" Foreground="#e8f5ee" FontSize="14" FontWeight="Bold"/>
                </Border>
                <ListBox x:Name="lstBeete" Height="120" Margin="8,4,8,4"/>
                <!--rechts Pflanzen-->
                <Border Background="#1a6b4a" Padding="8" HorizontalAlignment="Stretch">
                    <TextBlock Text="Pflanzenliste" Foreground="#e8f5ee" FontSize="14" FontWeight="Bold"/>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200">
                <!--HIER PFLANZENBUTTONS-->
                    <StackPanel MaxHeight="200">
                        <RadioButton Content="🍅 Paradaiser" Tag="Paradaiser" Margin="8,6,8,2" IsChecked="False" Checked="PflanzeAuswaehlen"/>
                              <!--Methode aufrufen bei checked angehakerlt-->
                        <RadioButton Content="🥒 Gurke" Tag="Gurke" Margin="8,6,8,2" IsChecked="False" Checked="PflanzeAuswaehlen"/>
                        <RadioButton Content="🌶️ Chilli" Tag="Chilli" Margin="8,6,8,2" Checked="PflanzeAuswaehlen"/>
                        <RadioButton Content="🥕 Karotte" Tag="Karotte" Margin="8,6,8,2" Checked="PflanzeAuswaehlen"/>
                        <RadioButton Content="🥬 Salat" Tag="Salat" Margin="8,6,8,2" Checked="PflanzeAuswaehlen"/>
                        <RadioButton Content="🫑 Paprika" Tag="Paprika" Margin="8,6,8,2" Checked="PflanzeAuswaehlen"/>
                        <RadioButton Content="🍆 Aubergine" Tag="Aubergine" Margin="8,6,8,2" Checked="PflanzeAuswaehlen"/>
                        <RadioButton Content="🥦 Zucchini" Tag="Zucchini" Margin="8,6,8,2" Checked="PflanzeAuswaehlen"/>
                    </StackPanel>
                </ScrollViewer>
                
            </StackPanel>
            </ScrollViewer>
                
                       
        </Grid>
        <!--"Footer" Buttons-->
        <Grid Grid.Row="2" Background="#1a6b4a">
            <StackPanel Orientation="Horizontal" Margin="8,4,8,4">
                <Button x:Name="btnZufall" Content="🎲 Zufallsbeet" Margin="4,6,4,6" Click="btnZufall_Click"/>
                <Button x:Name="btnSpeichern" Content="💾 Speichern" Margin="4,6,4,6" Click="btnSpeichern_Click"/>
                 <Button x:Name="btnLaden" Content="📂 Laden" Margin="4,6,4,6" Click="btnLaden_Click"/>
                <!--<Button x:Name="btnNeu" Content="🌱 Neu" Margin="4,6,4,6"/>-->
                <Button x:Name="btnLoeschen" Content="🗑 Löschen" Margin="4,6,4,6" Click="btnLoeschen_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
