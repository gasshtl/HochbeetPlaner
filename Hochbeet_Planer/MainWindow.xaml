<Window x:Class="Hochbeet_Planer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hochbeet_Planer"
        mc:Ignorable="d"
        Title="Hochbeet Planer Editor" Height="600" Width="1000">
    <!--Titelbalken oben "Hochbeet Planer Editor"-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#1a6b4a" Padding="10">
            <TextBlock Text="Hochbeet Planer Editor" Foreground="#e8f5ee" FontSize="18" FontWeight="Bold"/>
        </Border>
        <!--Hauptbereich der Seite (Beet mittig & Pflanzen rechts)-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            <!--rechts Maße-->
            <StackPanel Grid.Column="1" Background="#f0f0e0" Margin="0" Width="auto">
                <Border Background="#1a6b4a" Padding="8" HorizontalAlignment="Stretch">
                    <TextBlock Text="Hochbeet Maße" Foreground="#e8f5ee" FontSize="14" FontWeight="Bold"/>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="8,8,8,4">
                    <TextBlock Text="Breite(cm):" VerticalAlignment="Center" Margin=" 0,0,8,0" />
                    <TextBox x:Name="txtBreite" Width="80"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,4,8,8">
                    <TextBlock Text="Länge(cm):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="txtLaenge" Width="80"/>
                </StackPanel>
                <Button x:Name="btnBeetGenerieren" Content="Beet generieren" Margin="8,4,8,8" Background="#1a6b4a" Foreground="#e8f5ee"/>
                <!--rechts Pflanzen-->
                <Border Background="#1a6b4a" Padding="8" HorizontalAlignment="Stretch">
                    <TextBlock Text="Pflanzenliste" Foreground="#e8f5ee" FontSize="14" FontWeight="Bold"/>
                </Border>
                <RadioButton x:Name="rbParadaiser" Content="🍅 Paradaiser" Margin="8,6,8,2" IsChecked="False"/>

            </StackPanel>
            
        </Grid>
    </Grid>
</Window>
